# Copy to .env and fill in. Every script in this module reads from here.
# .env is gitignored at the repo root — never commit real keys.

# --- API keys -------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Only needed for the embeddings/ and rag/ modules (Anthropic-recommended embeddings).
VOYAGE_API_KEY=pa-...

# --- Models (override to control cost) ------------------------------------
# The whole module runs against these. Defaults are the capable tier; switch to
# the cheaper tier below while learning to cut spend by ~5-10x.
#
# Cheap learning setup:
  ANTHROPIC_MODEL=claude-haiku-4-5
  OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4o

# Embeddings models
OPENAI_EMBED_MODEL=text-embedding-3-small
VOYAGE_EMBED_MODEL=voyage-3
