{% extends "base.njk" %}

{% block header %}Password Reset{% endblock %}

{% block body %}
  <p>Hi {{ name }},</p>
  <p>We received a request to reset the password for your account
     (<strong>{{ email }}</strong>).</p>
  <p>Click the button below to choose a new password:</p>
  <a class="btn" href="{{ resetUrl }}">Reset Password</a>
  <p>This link expires in <strong>{{ expiresMinutes }} minutes</strong>.</p>
  <p>
    If you didn't request a password reset, your account is safe —
    just ignore this email. No changes have been made.
  </p>
  <p>— The My App Team</p>
{% endblock %}
