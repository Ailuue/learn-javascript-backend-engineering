<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
  <style>
    body  { font-family: -apple-system, Arial, sans-serif; background: #f4f4f4; margin: 0; padding: 20px; }
    .wrap { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 6px; overflow: hidden; }
    .hdr  { background: #1a1a2e; color: #fff; padding: 24px 32px; }
    .hdr h1 { margin: 0; font-size: 22px; }
    .body { padding: 32px; color: #333; line-height: 1.6; }
    .btn  { display: inline-block; background: #4f46e5; color: #fff; padding: 12px 28px;
            border-radius: 4px; text-decoration: none; font-weight: 600; margin: 16px 0; }
    .ftr  { background: #f4f4f4; padding: 16px 32px; font-size: 12px; color: #888; }
    .ftr a { color: #888; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="hdr"><h1>{% block header %}My App{% endblock %}</h1></div>
    <div class="body">{% block body %}{% endblock %}</div>
    <div class="ftr">
      {% block footer %}
        &copy; {{ year }} My App &middot;
        <a href="#">Unsubscribe</a>
      {% endblock %}
    </div>
  </div>
</body>
</html>
