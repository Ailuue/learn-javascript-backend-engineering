# ─── 01 · Basics ──────────────────────────────────────────────────────────────
#
# Concepts:
#   1. Anatomy of a rule: target, prerequisites, recipe
#   2. Default target — first rule in the file (or .DEFAULT_GOAL)
#   3. .PHONY — targets that are NOT files
#   4. Tab requirement — recipes MUST start with a hard tab, not spaces
#   5. @ prefix — suppress command echo
#   6. make -n — dry-run mode
#   7. make -f — run a specific Makefile
#
# Try:
#   make            # runs the default target (hello)
#   make clean      # removes the output file
#   make about      # echoes a multi-line message
#   make -n hello   # prints what would run without running it
# ─────────────────────────────────────────────────────────────────────────────

# CONCEPT 2: The first rule is the default goal.
# Running `make` with no arguments runs this target.
# You can also set it explicitly:
.DEFAULT_GOAL := hello

# CONCEPT 1: A rule has three parts:
#
#   target: prerequisites
#   	recipe
#
# target       — the name of the file to build (or a phony label)
# prerequisites — files or other targets that must exist/run first
# recipe        — shell command(s) to run; MUST start with a TAB character
#
hello:
	@echo "Hello from make!"
	@echo "This is the default target because it appears first."

# CONCEPT 3: .PHONY tells make these targets are NOT file names.
#
# Without .PHONY, if a file named "clean" exists in this directory,
# `make clean` would see the file is already up to date and do nothing.
# .PHONY forces the recipe to run regardless of whether the file exists.
#
.PHONY: hello clean about greet write-file rebuild-demo

clean:
	@echo "Removing output.txt (if it exists)..."
	rm -f output.txt

# CONCEPT 5: The @ prefix suppresses echoing the command itself.
#
# Without @:
#   $ make hello
#   echo "Hello from make!"    ← make prints the command
#   Hello from make!           ← the command's output
#
# With @:
#   $ make hello
#   Hello from make!           ← only the output, command is hidden
#
# Rules of thumb:
#   - Use @ on almost everything (cleaner output)
#   - Omit @ when the command itself is informative (e.g. `ls` output)
#   - Never suppress on recipe lines used for debugging

about:
	@echo "──────────────────────────────────────────"
	@echo " Makefile basics"
	@echo " Run 'make -n <target>' to preview commands"
	@echo " Run 'make -B <target>' to force a rebuild"
	@echo "──────────────────────────────────────────"

# CONCEPT: A recipe can have multiple lines.
# Each line runs in its own shell — variables set in one line are gone by the next.
#
# BAD (x is lost between lines):
#   x=hello
#   echo $$x         # prints nothing
#
# GOOD (single logical line with backslash continuation):
#   x=hello; \
#   echo $$x         # prints "hello"
#
greet:
	@name="world"; \
	echo "Hello, $$name!"

# CONCEPT: Targets CAN be real files.
# This target creates output.txt. If output.txt already exists and is newer
# than its prerequisites, make skips the recipe ("Nothing to be done for...").
#
output.txt:
	@echo "Creating output.txt..."
	echo "Generated by make on $$(date)" > output.txt

# CONCEPT: Phony targets can depend on file targets.
# `write-file` depends on output.txt — make runs output.txt's recipe first.
#
write-file: output.txt
	@echo "output.txt is ready."
	@cat output.txt

# CONCEPT: Forcing a rebuild with -B
# Even if output.txt exists and is up to date, this runs the recipe:
#   make -B output.txt
#
# The rebuild-demo target shows you what's in the file before and after:
rebuild-demo: output.txt
	@echo "Current contents of output.txt:"
	@cat output.txt
	@echo ""
	@echo "Run 'make -B output.txt' to regenerate it."
