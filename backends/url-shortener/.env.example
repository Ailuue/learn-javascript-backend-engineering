# Copy to .env and adjust. For local SQLite a file URL works; for production
# switch the Prisma datasource provider to "postgresql" and point this at
# Postgres.
DATABASE_URL=file:./prisma/dev.db
BASE_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30
